# ---------------------------------------------------------------------------
# Copy to backend/.env for local development. NEVER commit the real .env.
# In production these live in the Render dashboard (backend) and GitHub
# repository Secrets (CI).
# ---------------------------------------------------------------------------

# --- LLM providers (at least one required) ---------------------------------
# Groq keys start with 'gsk_' and come from console.groq.com.
# (Groq != Grok. An 'xai-' key belongs to a different company and will 401.)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- Model IDs -------------------------------------------------------------
# Leave blank to use the code defaults. Only set these when the smoke test
# reports a model has been retired — that is what this escape hatch is for.
GROQ_MODEL=
GEMINI_MODEL=
# OpenRouter's free lineup rotates; there is no safe default.
# Run `python scripts/smoke_test.py --list-free` to see what is free today.
OPENROUTER_MODEL=

# --- Embeddings (Gemini free) ----------------------------------------------
# text-embedding-004 was shut down 2026-01-14; gemini-embedding-001 replaces it.
# It supports 768 / 1536 / 3072 output dimensions.
EMBEDDING_MODEL=gemini-embedding-001
# MUST match the dimension of the Upstash Vector index.
EMBEDDING_DIMENSIONS=1536

# --- Vector DB (Upstash) — needed from M3 -----------------------------------
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# --- App config -------------------------------------------------------------
ALLOWED_ORIGIN=http://localhost:3000,https://traveling-foodie-agent-public-edition.vercel.app
PUBLIC_APP_URL=https://traveling-foodie-agent-public-edition.vercel.app
DEFAULT_TIER=2
LLM_TIMEOUT_S=45
LLM_RETRIES=1
DEBUG=false
