# ---------------------------------------------------------------------------
# Copy to backend/.env for local development. NEVER commit the real .env.
# In production these live in the Render dashboard (backend) and GitHub
# repository Secrets (CI).
# ---------------------------------------------------------------------------

# --- LLM providers (at least one required) ---------------------------------
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- Model IDs (override without redeploy; verified by the M0 smoke test) ---
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Embeddings (Gemini free) ----------------------------------------------
EMBEDDING_MODEL=text-embedding-004
# MUST match the dimension of the Upstash Vector index.
EMBEDDING_DIMENSIONS=768

# --- Vector DB (Upstash) — needed from M3 -----------------------------------
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# --- App config -------------------------------------------------------------
ALLOWED_ORIGIN=http://localhost:3000,https://traveling-foodie-agent-public-edition.vercel.app
PUBLIC_APP_URL=https://traveling-foodie-agent-public-edition.vercel.app
DEFAULT_TIER=2
LLM_TIMEOUT_S=45
LLM_RETRIES=1
DEBUG=false
